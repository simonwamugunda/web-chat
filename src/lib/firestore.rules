rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Allow anonymous (request.auth != null when using anonymous auth)
    // to read/write rooms and messages.

    match /rooms/{roomId} {
      allow read, write: if request.auth != null;

      match /messages/{messageId} {
        allow read, write: if request.auth != null;
      }
    }

    // Also allow listing/reading the top-level collection.
    match /rooms {
      allow read, write: if request.auth != null;
    }
  }
}

